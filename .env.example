# =============================================================================
# .env.example — PepperBot 金融账号自动化运营系统
# =============================================================================
# Per UNIFIED_SPEC.md §5.5. Copy to .env.local for dev; never commit secrets.
# Items marked "# SECRET" must NEVER be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM backend
# -----------------------------------------------------------------------------
LLM_BACKEND=claude_cli              # dev: claude_cli | prod: moonshot
CLAUDE_MODEL=claude-sonnet-4-6      # dev only
CLAUDE_CLI_PATH=claude              # dev only — path to claude CLI
MOONSHOT_MODEL=kimi-k2-0905-preview # prod only
MOONSHOT_API_KEY=<REDACTED>         # SECRET - do not commit (prod)
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# -----------------------------------------------------------------------------
# Browser backend (locked to playwright_headless for both dev + prod)
# -----------------------------------------------------------------------------
BROWSER_BACKEND=playwright_headless
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright  # prod (image-internal) only

# -----------------------------------------------------------------------------
# Twitter / X
# -----------------------------------------------------------------------------
TWITTER_HANDLE=@off_thetarget
TWITTER_COOKIE_FILE=/app/secrets/twitter_cookies.json   # SECRET - do not commit
# Small (xiaohao) account cookie for cross-reference monitor (§16.3)
TWITTER_XIAOHAO_COOKIE_FILE=/app/secrets/x_xiaohao_cookies.json   # SECRET - do not commit

# -----------------------------------------------------------------------------
# Xueqiu (雪球)
# -----------------------------------------------------------------------------
XUEQIU_COOKIE_FILE=/app/secrets/xueqiu_cookies.json   # SECRET - do not commit

# -----------------------------------------------------------------------------
# Futu (富途)
# -----------------------------------------------------------------------------
FUTU_COOKIE_FILE=/app/secrets/futu_cookies.json       # SECRET - do not commit

# -----------------------------------------------------------------------------
# Discord 闸门 (§16.1)
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=<REDACTED>        # SECRET - do not commit
DISCORD_CHANNEL_ID=1477872625526247577

# -----------------------------------------------------------------------------
# Paths & runtime
# -----------------------------------------------------------------------------
PEPPERBOT_ROOT=/app                 # prod: /app | dev: repo path
DB_PATH=/app/data/pepperbot.db      # prod | dev: data/pepperbot.db
LOG_DIR=/app/logs/                  # prod | dev: logs/

# -----------------------------------------------------------------------------
# Alerting (reuses Discord bot from secrets/discord.env; no separate webhook)
# -----------------------------------------------------------------------------
ALERT_CHANNEL_ID=                   # optional: override DISCORD_DRAFT_CHANNEL_ID
ALERT_THREAD_ID=                    # optional: post to a thread inside the channel

# -----------------------------------------------------------------------------
# Operations flags
# -----------------------------------------------------------------------------
DRY_RUN=1                           # dev: 1 (do not really post) | prod: 0
TZ=Asia/Shanghai                    # cron runs in UTC regardless
PYTHONUNBUFFERED=1

# === Discord (S13 gateway) ===
# Token stored in secrets/discord.env (not in this file)
DISCORD_BOT_TOKEN=<set in secrets/discord.env>
DISCORD_DRAFT_CHANNEL_ID=<set in secrets/discord.env>

# === Main account identity (for self_monitor cross-reference) ===
TWITTER_HANDLE=off_tehtarget

# === Discord approval mode ===
# manual = ✅ just marks approved, user posts manually, self_monitor binds back
# auto   = ✅ triggers publisher.post_tweet (needs x_dahao cookie + risk)
DISCORD_APPROVAL_MODE=manual
